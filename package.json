{
  "name": "@xochi/sdk",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/circuits-browser.js",
      "types": "./dist/circuits-browser.d.ts"
    },
    "./node": {
      "import": "./dist/circuits.js",
      "types": "./dist/circuits.d.ts"
    },
    "./circuits/*": "./circuits/*"
  },
  "files": [
    "dist",
    "circuits"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:integration": "vitest run test/integration.test.ts"
  },
  "dependencies": {
    "@aztec/bb.js": "4.0.0-nightly.20260120",
    "@noir-lang/noir_js": "1.0.0-beta.19"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "~5.6.2",
    "viem": "^2.21.0",
    "vitest": "^4.0.0"
  }
}
