{
  "name": "@xochi/sdk",
  "version": "0.2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/circuits-browser.js",
      "types": "./dist/circuits-browser.d.ts"
    },
    "./node": {
      "import": "./dist/circuits.js",
      "types": "./dist/circuits.d.ts"
    },
    "./provider": {
      "import": "./dist/provider/index.js",
      "types": "./dist/provider/index.d.ts"
    },
    "./circuits/*": "./circuits/*"
  },
  "license": "MIT",
  "files": [
    "dist",
    "circuits"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit && tsc -p daemon/tsconfig.json",
    "test": "vitest run",
    "test:integration": "vitest run test/integration*.test.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"daemon/src/**/*.ts\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"daemon/src/**/*.ts\" \"*.{json,md}\"",
    "daemon": "node --experimental-strip-types daemon/src/index.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run format:check && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@aztec/bb.js": "4.0.0-nightly.20260120",
    "@noble/curves": "^1.9.0",
    "@noir-lang/noir_js": "1.0.0-beta.19"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "prettier": "^3.3.3",
    "typescript": "~5.6.2",
    "viem": "^2.21.0",
    "vitest": "^4.0.0"
  }
}
